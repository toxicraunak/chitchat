let currentTheme = JSON.parse(localStorage.getItem('chatThemeV3')||'null') || {type:'solid',id:'dark',bg:'linear-gradient(160deg,#0e1621 0%,#1a2535 100%)'};

function applyTheme(theme){
  currentTheme=theme;
  localStorage.setItem('chatThemeV3',JSON.stringify(theme));
  const bgLayer=document.getElementById('bgLayer');
  if(theme.type==='solid'){
    bgLayer.style.backgroundImage='none';
    bgLayer.style.background=theme.bg;
  } else {
    // Uploaded background image: show as-is, no crop/zoom, no scroll movement
    bgLayer.style.background='';
    bgLayer.style.backgroundImage=`url("${theme.bg}")`;
    bgLayer.style.backgroundSize='100% 100%'; // stretch to fit exactly, no cropping/zoom
    bgLayer.style.backgroundPosition='center center';
    bgLayer.style.backgroundRepeat='no-repeat';
  }
  document.querySelectorAll('.th-swatch').forEach(s=>s.classList.toggle('active',s.dataset.id===theme.id));
  document.querySelectorAll('.th-bg-item').forEach(s=>s.classList.toggle('active',s.dataset.id===theme.id));
}
