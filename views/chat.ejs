<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no,viewport-fit=cover">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title><%=user==='tanji'?'Hinata':'Tanji'%> — TanjiChat</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
:root{
  --bg:#0e1621;--header:#17212b;--msg-in:#182533;--msg-out:#2b5278;
  --accent:#2AABEE;--text:#e8eaed;--muted:#7d8b99;--border:rgba(255,255,255,.07);
  --hover:rgba(255,255,255,.05);
  --safe-top:env(safe-area-inset-top,0px);--safe-bot:env(safe-area-inset-bottom,0px);
}
html,body{height:100%;overflow:hidden;background:var(--bg);font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;color:var(--text);}
#app{display:flex;flex-direction:column;height:100dvh;position:fixed;inset:0;}

/* HEADER */
.hdr{background:rgba(23,33,43,.95);backdrop-filter:blur(10px);display:flex;align-items:center;gap:10px;padding:8px 12px;padding-top:calc(8px + var(--safe-top));border-bottom:1px solid var(--border);flex-shrink:0;min-height:56px;z-index:30;}
.hdr-back{color:var(--accent);font-size:24px;padding:6px;text-decoration:none;display:flex;align-items:center;flex-shrink:0;border-radius:50%;}
.hdr-back:active{background:var(--hover);}
.hdr-av{width:38px;height:38px;border-radius:50%;flex-shrink:0;background:linear-gradient(135deg,#2AABEE,#7B5EA7);display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:700;color:#fff;cursor:pointer;position:relative;overflow:hidden;border:2px solid transparent;transition:border-color .2s;}
.hdr-av img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;border-radius:50%;}
.hdr-av:active{border-color:var(--accent);}
.hdr-info{flex:1;min-width:0;}
.hdr-name{font-size:15px;font-weight:600;}
.hdr-status{font-size:12px;color:var(--muted);}
.hdr-status.on{color:#4dce7a;}
.hdr-btn{width:40px;height:40px;border-radius:50%;border:none;background:transparent;color:var(--muted);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
.hdr-btn:active{background:var(--hover);}

/* BACKGROUND LAYER — fixed, never scrolls, never zoomed */
#bgLayer{
  position:absolute; inset:0; z-index:0;
  background-color:var(--bg);
  background-repeat:no-repeat;
  background-position:center center;
  background-size:cover;
  pointer-events:none;
}

/* MESSAGES */
.msgs-wrap{flex:1;position:relative;overflow:hidden;}
#msgs{position:absolute;inset:0;overflow-y:auto;overflow-x:hidden;padding:10px 8px 8px;display:flex;flex-direction:column;-webkit-overflow-scrolling:touch;overscroll-behavior-y:contain;z-index:1;background:transparent;}
#msgs::-webkit-scrollbar{display:none;}

/* Top loader for pagination (older messages) */
.top-loader{display:none;align-items:center;justify-content:center;padding:10px;flex-shrink:0;}
.top-loader.show{display:flex;}
.mini-spin{width:20px;height:20px;border:2px solid rgba(42,171,238,.2);border-top-color:var(--accent);border-radius:50%;animation:spin .7s linear infinite;}
@keyframes spin{to{transform:rotate(360deg)}}

.date-sep{text-align:center;margin:10px 0;pointer-events:none;flex-shrink:0;}
.date-sep span{background:rgba(0,0,0,.55);backdrop-filter:blur(4px);color:var(--muted);font-size:11px;padding:3px 12px;border-radius:20px;}

/* ROW */
.row{display:flex;align-items:flex-end;gap:6px;margin-bottom:1px;padding:2px 4px;border-radius:10px;position:relative;touch-action:pan-y;will-change:transform;flex-shrink:0;}
.row.out{flex-direction:row-reverse;}
.row.hl{background:rgba(42,171,238,.14);}
.row.sw{transition:none;}
.sw-arr{position:absolute;top:50%;transform:translateY(-50%);color:var(--accent);font-size:18px;opacity:0;pointer-events:none;z-index:2;}
.row.in .sw-arr{left:40px;}
.row.out .sw-arr{right:4px;}

/* AVATAR */
.msg-av{width:26px;height:26px;border-radius:50%;flex-shrink:0;background:linear-gradient(135deg,#7B5EA7,#2AABEE);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff;position:relative;overflow:hidden;align-self:flex-end;}
.msg-av img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;border-radius:50%;}

/* BUBBLE */
.bbl{max-width:75%;min-width:52px;padding:7px 10px;border-radius:14px;font-size:14px;line-height:1.45;word-break:break-word;position:relative;}
.row.in .bbl{background:rgba(24,37,51,.92);backdrop-filter:blur(4px);border-bottom-left-radius:3px;}
.row.out .bbl{background:rgba(43,82,120,.92);backdrop-filter:blur(4px);border-bottom-right-radius:3px;}
.bbl.stk{background:transparent!important;backdrop-filter:none!important;padding:2px;}

/* REPLY IN BUBBLE */
.rp-box{background:rgba(255,255,255,.08);border-left:3px solid var(--accent);border-radius:6px;padding:5px 8px;margin-bottom:6px;cursor:pointer;}
.rp-name{font-size:11px;color:var(--accent);font-weight:600;margin-bottom:2px;}
.rp-txt{font-size:12px;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;display:flex;align-items:center;gap:5px;}
.rp-stk-th{width:26px;height:26px;object-fit:contain;border-radius:3px;}

/* STICKER */
.stk-img{width:130px;height:130px;object-fit:contain;display:block;border-radius:8px;}

/* IMAGE */
.msg-img{max-width:240px;max-height:240px;object-fit:cover;border-radius:10px;display:block;cursor:pointer;margin-bottom:2px;}
.msg-img.loading{background:rgba(255,255,255,.05);min-height:120px;min-width:160px;}

/* FILE */
.file-row{display:flex;align-items:center;gap:8px;text-decoration:none;color:inherit;min-width:160px;}
.file-ico{font-size:26px;flex-shrink:0;}
.file-nm{font-size:13px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:160px;}
.file-sz{font-size:11px;color:var(--muted);margin-top:1px;}

/* META */
.meta{display:flex;align-items:center;gap:3px;justify-content:flex-end;margin-top:3px;}
.meta-time{font-size:10px;color:rgba(255,255,255,.35);}
.meta-tick{font-size:12px;color:rgba(255,255,255,.35);}
.meta-tick.rd{color:var(--accent);}

/* REACTIONS */
.r-row{display:flex;flex-wrap:wrap;gap:4px;margin-top:5px;}
.r-chip{display:flex;align-items:center;gap:2px;background:rgba(255,255,255,.09);border:1px solid rgba(255,255,255,.13);border-radius:20px;padding:3px 8px;font-size:15px;cursor:pointer;transition:background .1s;user-select:none;line-height:1;}
.r-chip .r-cnt{font-size:11px;color:var(--muted);font-weight:600;}
.r-chip.mine{background:rgba(42,171,238,.2);border-color:rgba(42,171,238,.45);}
.r-chip:active{transform:scale(.9);}

/* TYPING */
.typing-row{display:none;align-items:center;gap:8px;padding:4px 4px 8px 40px;flex-shrink:0;}
.typing-row.show{display:flex;}
.dots span{width:7px;height:7px;border-radius:50%;background:var(--muted);display:inline-block;animation:bop 1.2s infinite;}
.dots{display:flex;gap:4px;}
.dots span:nth-child(2){animation-delay:.2s;}
.dots span:nth-child(3){animation-delay:.4s;}
@keyframes bop{0%,80%,100%{transform:scale(.75);opacity:.5}40%{transform:scale(1);opacity:1}}

/* REPLY BAR */
.rp-bar{display:none;background:rgba(23,33,43,.97);border-top:1px solid var(--border);padding:8px 12px;align-items:center;gap:10px;flex-shrink:0;}
.rp-bar.show{display:flex;}
.rp-bar-info{flex:1;min-width:0;}
.rp-bar-name{font-size:12px;color:var(--accent);font-weight:600;}
.rp-bar-txt{font-size:13px;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;display:flex;align-items:center;gap:5px;}
.rp-bar-stk{width:28px;height:28px;object-fit:contain;border-radius:3px;}
.rp-close{background:none;border:none;color:var(--muted);font-size:20px;cursor:pointer;padding:4px;border-radius:50%;display:flex;}

/* STICKER PANEL */
#stkPanel{display:none;background:rgba(23,33,43,.98);border-top:1px solid var(--border);flex-shrink:0;max-height:260px;}
#stkPanel.show{display:flex;flex-direction:column;}
.stk-tabs{display:flex;gap:0;overflow-x:auto;padding:8px 8px 0;border-bottom:1px solid var(--border);flex-shrink:0;}
.stk-tabs::-webkit-scrollbar{display:none;}
.stk-tab{flex-shrink:0;width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;cursor:pointer;border:2px solid transparent;overflow:hidden;margin-right:6px;transition:border-color .15s;background:rgba(255,255,255,.04);font-size:18px;color:var(--muted);}
.stk-tab img{width:100%;height:100%;object-fit:contain;}
.stk-tab.active{border-color:var(--accent);}
.stk-tab:active{transform:scale(.9);}
.stk-body{overflow-y:auto;padding:8px;-webkit-overflow-scrolling:touch;flex:1;position:relative;}
.stk-body::-webkit-scrollbar{display:none;}
.stk-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(68px,1fr));gap:6px;}
.stk-cell{aspect-ratio:1;border-radius:10px;background:rgba(255,255,255,.04);cursor:pointer;display:flex;align-items:center;justify-content:center;overflow:hidden;}
.stk-cell:active{transform:scale(.88);}
.stk-cell img{width:100%;height:100%;object-fit:contain;padding:3px;}
.stk-empty{text-align:center;padding:24px;color:var(--muted);font-size:13px;grid-column:1/-1;}
.stk-loading{display:flex;align-items:center;justify-content:center;padding:32px;grid-column:1/-1;}

/* INPUT */
.inp-area{background:rgba(23,33,43,.98);border-top:1px solid var(--border);padding:6px 8px;padding-bottom:calc(6px + var(--safe-bot));display:flex;align-items:flex-end;gap:6px;flex-shrink:0;}
.inp-ico{width:40px;height:40px;border-radius:50%;border:none;background:transparent;color:var(--muted);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;}
.inp-ico:active{background:var(--hover);}
.inp-box{flex:1;background:rgba(255,255,255,.07);border:1px solid var(--border);border-radius:20px;padding:9px 14px;color:var(--text);font-size:15px;outline:none;resize:none;max-height:120px;min-height:40px;line-height:1.45;font-family:inherit;-webkit-appearance:none;}
.inp-box:focus{border-color:rgba(42,171,238,.4);}
.inp-box::placeholder{color:var(--muted);}
.send-btn{width:40px;height:40px;border-radius:50%;border:none;background:var(--accent);color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
.send-btn:active{transform:scale(.9);}

/* EMOJI REACTION PICKER */
#emojiPicker{display:none;position:fixed;z-index:600;background:rgba(30,44,58,.98);backdrop-filter:blur(16px);border-radius:20px;padding:10px 8px 8px;box-shadow:0 8px 40px rgba(0,0,0,.7);border:1px solid rgba(255,255,255,.1);min-width:280px;max-width:320px;}
#emojiPicker.show{display:block;}
.ep-scroll{display:flex;flex-wrap:wrap;gap:2px;max-height:160px;overflow-y:auto;}
.ep-scroll::-webkit-scrollbar{display:none;}
.ep-e{font-size:26px;cursor:pointer;padding:5px;border-radius:10px;transition:background .1s;user-select:none;line-height:1;}
.ep-e:active{background:rgba(255,255,255,.15);transform:scale(1.2);}
.ep-divider{width:100%;height:1px;background:var(--border);margin:6px 0;}
.ep-reply{display:flex;align-items:center;gap:8px;padding:8px 6px;cursor:pointer;border-radius:10px;font-size:14px;color:var(--text);}
.ep-reply:active{background:var(--hover);}

/* THEME PICKER */
#themePicker{display:none;position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:700;align-items:flex-end;justify-content:center;}
#themePicker.show{display:flex;}
.th-sheet{background:#17212b;border-radius:20px 20px 0 0;padding:16px;padding-bottom:calc(16px + var(--safe-bot));width:100%;max-width:480px;max-height:85vh;overflow-y:auto;}
.th-sheet h3{font-size:16px;font-weight:700;margin-bottom:14px;text-align:center;}
.th-section{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin:12px 0 8px;}
.th-solid-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:4px;}
.th-swatch{aspect-ratio:1;border-radius:12px;cursor:pointer;border:2px solid transparent;overflow:hidden;position:relative;transition:border-color .15s;}
.th-swatch.active{border-color:var(--accent);}
.th-swatch:active{transform:scale(.92);}
.th-swatch span{position:absolute;bottom:3px;left:0;right:0;text-align:center;font-size:9px;color:#fff;text-shadow:0 1px 4px rgba(0,0,0,.9);}
.th-bg-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:12px;}
.th-bg-item{aspect-ratio:9/16;border-radius:10px;cursor:pointer;border:2px solid transparent;overflow:hidden;position:relative;background:rgba(255,255,255,.04);}
.th-bg-item.active{border-color:var(--accent);}
.th-bg-item:active{transform:scale(.94);}
.th-bg-item img{width:100%;height:100%;object-fit:cover;}
.th-close{display:block;width:100%;padding:13px;border-radius:12px;border:none;background:rgba(255,255,255,.07);color:var(--text);font-size:15px;font-weight:600;cursor:pointer;margin-top:8px;}

/* AVATAR SHEET */
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:200;align-items:flex-end;justify-content:center;}
.overlay.show{display:flex;}
.sheet{background:#17212b;border-radius:20px 20px 0 0;padding:20px;width:100%;max-width:480px;padding-bottom:calc(20px + var(--safe-bot));}
.sheet h3{font-size:16px;font-weight:700;margin-bottom:16px;text-align:center;}
.sheet-av{width:72px;height:72px;border-radius:50%;margin:0 auto 16px;background:linear-gradient(135deg,#2AABEE,#7B5EA7);display:flex;align-items:center;justify-content:center;font-size:28px;font-weight:700;color:#fff;position:relative;overflow:hidden;}
.sheet-av img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;}
.sh-btn{display:block;width:100%;padding:13px;border-radius:12px;border:none;font-size:15px;font-weight:600;cursor:pointer;margin-bottom:10px;}
.sh-btn.pri{background:var(--accent);color:#fff;}
.sh-btn.sec{background:rgba(255,255,255,.07);color:var(--text);}
.sh-btn:active{opacity:.8;}

/* IMAGE VIEWER */
#imgV{display:none;position:fixed;inset:0;background:rgba(0,0,0,.95);z-index:300;align-items:center;justify-content:center;}
#imgV.show{display:flex;}
#imgV img{max-width:95vw;max-height:85vh;object-fit:contain;border-radius:8px;}
.iv-close{position:absolute;top:calc(16px + var(--safe-top));right:16px;color:#fff;font-size:26px;cursor:pointer;width:40px;height:40px;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.5);border-radius:50%;}

/* TOAST */
.toast{position:fixed;bottom:90px;left:50%;transform:translateX(-50%);background:rgba(36,47,61,.97);backdrop-filter:blur(8px);border-radius:12px;padding:10px 16px;font-size:13px;z-index:900;display:none;align-items:center;gap:8px;white-space:nowrap;box-shadow:0 4px 20px rgba(0,0,0,.5);border:1px solid var(--border);}
.toast.show{display:flex;}

/* Loading overlay - quick, only for initial 20 messages */
#loadingOverlay{position:fixed;inset:0;background:var(--bg);z-index:1000;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:16px;}
#loadingOverlay.hidden{display:none;}
.load-spinner{width:36px;height:36px;border:3px solid rgba(42,171,238,.2);border-top-color:var(--accent);border-radius:50%;animation:spin .8s linear infinite;}
.load-txt{font-size:14px;color:var(--muted);}
</style>
</head>
<body>
<input type="file" id="avInput" accept="image/*" style="display:none">
<input type="file" id="fileInput" accept="*/*" style="display:none">

<div id="loadingOverlay">
  <div class="load-spinner"></div>
  <div class="load-txt">Loading chat...</div>
</div>

<div id="app">
  <!-- HEADER -->
  <div class="hdr">
    <a href="/" class="hdr-back">‹</a>
    <div class="hdr-av" id="otherAv" onclick="openAvSheet()">
      <%if(otherProfile.avatar){%><img src="<%=otherProfile.avatar%>" alt=""><%}else{%><%=user==='tanji'?'H':'T'%><%}%>
    </div>
    <div class="hdr-info">
      <div class="hdr-name"><%=user==='tanji'?'Hinata':'Tanji'%></div>
      <div class="hdr-status" id="statusTxt">last seen recently</div>
    </div>
    <button class="hdr-btn" onclick="triggerCall()">📞</button>
    <button class="hdr-btn" onclick="openTheme()">🎨</button>
  </div>

  <!-- MESSAGES -->
  <div class="msgs-wrap">
    <div id="bgLayer"></div>
    <div id="msgs">
      <div class="top-loader" id="topLoader"><div class="mini-spin"></div></div>
      <div class="typing-row" id="typRow">
        <div class="dots"><span></span><span></span><span></span></div>
        <span id="typName" style="font-size:12px;color:var(--muted)"></span>
      </div>
    </div>
  </div>

  <!-- REPLY BAR -->
  <div class="rp-bar" id="rpBar">
    <span style="color:var(--accent);font-size:18px;flex-shrink:0">↩</span>
    <div class="rp-bar-info">
      <div class="rp-bar-name" id="rpName"></div>
      <div class="rp-bar-txt" id="rpTxt"></div>
    </div>
    <button class="rp-close" onclick="clearReply()">✕</button>
  </div>

  <!-- STICKER PANEL -->
  <div id="stkPanel">
    <div class="stk-tabs" id="stkTabs"></div>
    <div class="stk-body"><div class="stk-grid" id="stkGrid"></div></div>
  </div>

  <!-- INPUT -->
  <div class="inp-area">
    <button class="inp-ico" onclick="document.getElementById('fileInput').click()">📎</button>
    <textarea class="inp-box" id="msgBox" placeholder="Message..." rows="1"></textarea>
    <button class="inp-ico" id="stkBtn" onclick="toggleStk()">😊</button>
    <button class="send-btn" onclick="doSend()">➤</button>
  </div>
</div>

<!-- EMOJI REACTION PICKER -->
<div id="emojiPicker">
  <div class="ep-scroll" id="epScroll"></div>
  <div class="ep-divider"></div>
  <div class="ep-reply" onclick="replyFromPicker()">↩ <span>Reply to message</span></div>
</div>

<!-- THEME PICKER -->
<div id="themePicker" onclick="closeThemeOut(event)">
  <div class="th-sheet">
    <h3>🎨 Chat Theme</h3>
    <div class="th-section">Solid Colors</div>
    <div class="th-solid-grid" id="solidGrid"></div>
    <div class="th-section">Background Images</div>
    <div class="th-bg-grid" id="bgGrid">
      <div style="color:var(--muted);font-size:12px;grid-column:1/-1;text-align:center;padding:12px">Loading...</div>
    </div>
    <button class="th-close" onclick="closeTheme()">Done</button>
  </div>
</div>

<!-- AVATAR SHEET -->
<div class="overlay" id="avSheet" onclick="closeSheet(event)">
  <div class="sheet">
    <h3>Your Photo</h3>
    <div class="sheet-av" id="shAvPrev"><%=user==='tanji'?'T':'H'%></div>
    <button class="sh-btn pri" onclick="document.getElementById('avInput').click()">📷 Change Photo</button>
    <button class="sh-btn sec" onclick="document.getElementById('avSheet').classList.remove('show')">Cancel</button>
  </div>
</div>

<!-- IMAGE VIEWER -->
<div id="imgV" onclick="closeImgV()">
  <span class="iv-close">✕</span>
  <img id="ivImg" src="" alt="">
</div>

<!-- TOAST -->
<div class="toast" id="toast"><span id="toastMsg"></span></div>

<script src="/socket.io/socket.io.js"></script>
<script>
const ME = '<%=user%>';
const OTHER = ME==='tanji'?'hinata':'tanji';
const MY_NAME = ME==='tanji'?'Tanji':'Hinata';
const OTHER_NAME = ME==='tanji'?'Hinata':'Tanji';
const PAGE_SIZE = 20;

let socket, replyData=null, pickerMsgId=null;
let typTimer=null, isTyp=false;
let lazyPacks=[], packStickerCache={}, activePack=0;
let hasMoreOlder=true, loadingOlder=false, oldestLoadedDate=null;
let initialLoadDone=false;

const ALL_REACTIONS = ['❤️','🔥','😂','👍','👎','😮','😢','🤥','🫶','💕','💗','👀','🤧','🥲','😭','🌝','🫠','😋','🥀','🤡','❤️‍🩹','😪','😚','🤣','🤤','🫤','😗','😘','👋','💋','🥹','✅','🙈','🤩','😍','🥰','🤯','😩','😫','😵','😖','🫨','🥸','💀','🌚'];

(function(){
  const sc=document.getElementById('epScroll');
  ALL_REACTIONS.forEach(e=>{
    const s=document.createElement('span'); s.className='ep-e'; s.textContent=e;
    s.onclick=()=>pickEmoji(e); sc.appendChild(s);
  });
})();

const SOLID_THEMES=[
  {id:'dark',label:'Dark',bg:'linear-gradient(160deg,#0e1621 0%,#1a2535 100%)'},
  {id:'night',label:'Night',bg:'#060b12'},
  {id:'ocean',label:'Ocean',bg:'linear-gradient(160deg,#061825 0%,#0d3b5e 100%)'},
  {id:'purple',label:'Purple',bg:'linear-gradient(160deg,#120820 0%,#2d1b4e 100%)'},
