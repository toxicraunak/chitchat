// ════════════ FAST INITIAL LOAD: REST API, only 20 messages ════════════
async function loadInitialMessages(){
  try{
    const res=await fetch('/api/messages?limit='+PAGE_SIZE);
    const data=await res.json();
    if(data.ok){
      renderInitialMessages(data.msgs);
      hasMoreOlder=data.hasMore;
      if(data.msgs.length) oldestLoadedDate=data.msgs[0].createdAt;
    }
  }catch(e){console.error('initial load failed',e);}
  initialLoadDone=true;
  document.getElementById('loadingOverlay').classList.add('hidden');
  syncAvatars();
  // Connect socket AFTER initial render for real-time updates
  connectSocket();
}
loadInitialMessages();

function connectSocket(){
  socket = io();
  socket.on('connect', ()=> socket.emit('join', ME));

  socket.on('newMessage', msg=>{
    if(!initialLoadDone) return;
    const wrap=document.getElementById('msgs');
    const rows=wrap.querySelectorAll('.row');
    if(rows.length>0){
      const ld=rows[rows.length-1].dataset.date;
      const nd=new Date(msg.createdAt).toDateString();
      if(ld!==nd) appendDate(new Date(msg.createdAt));
    }
    appendMsg(msg, true);
    scrollBot();
  });

  socket.on('reactionUpdate',({msgId,reactions})=>{
    const row=document.querySelector(`[data-id="${msgId}"]`); if(!row) return;
    const bbl=row.querySelector('.bbl'); if(!bbl) return;
    let rrow=bbl.querySelector('.r-row');
    if(!rrow){rrow=document.createElement('div');rrow.className='r-row';
      const meta=bbl.querySelector('.meta'); if(meta) bbl.insertBefore(rrow,meta); else bbl.appendChild(rrow);}
    renderReactions(rrow,reactions,msgId);
    if(!rrow.children.length) rrow.remove();
  });

  socket.on('typing',d=>{if(d.sender!==ME){document.getElementById('typName').textContent=OTHER_NAME;document.getElementById('typRow').classList.add('show');scrollBot();}});
  socket.on('stopTyping',()=>document.getElementById('typRow').classList.remove('show'));

  socket.on('onlineStatus',status=>{
    const el=document.getElementById('statusTxt');
    if(status[OTHER]){el.textContent='online';el.className='hdr-status on';}
    else{el.textContent='last seen recently';el.className='hdr-status';}
  });

  socket.on('avatarUpdate',({user,avatar})=>{
    if(user===OTHER){
      setAvImg(document.getElementById('otherAv'),avatar);
      document.querySelectorAll('.msg-av.oth').forEach(a=>setAvImg(a,avatar));
    } else { setAvImg(document.getElementById('shAvPrev'),avatar); }
  });

  socket.on('messagesRead',({by})=>{
    if(by===OTHER) document.querySelectorAll('.row.out .meta-tick').forEach(el=>{el.classList.add('rd');el.textContent='✓✓';});
  });
}

// ════════════ PAGINATION: load older messages on scroll-up ════════════
async function loadOlderMessages(){
  if(loadingOlder || !hasMoreOlder || !oldestLoadedDate) return;
  loadingOlder=true;
  document.getElementById('topLoader').classList.add('show');
  try{
    const res=await fetch('/api/messages?limit='+PAGE_SIZE+'&before='+encodeURIComponent(oldestLoadedDate));
    const data=await res.json();
    if(data.ok && data.msgs.length){
      prependOlderMessages(data.msgs);
      hasMoreOlder=data.hasMore;
      oldestLoadedDate=data.msgs[0].createdAt;
    } else {
      hasMoreOlder=false;
    }
  }catch(e){console.error('older load failed',e);}
  document.getElementById('topLoader').classList.remove('show');
  loadingOlder=false;
}

function prependOlderMessages(msgs){
  const wrap=document.getElementById('msgs');
  const topLoader=document.getElementById('topLoader');
  const prevScrollHeight=wrap.scrollHeight;
  const prevScrollTop=wrap.scrollTop;

  // Build fragment in chronological order, insert right after topLoader
  const frag=document.createDocumentFragment();
  let lastD=null;
  msgs.forEach(m=>{
    const d=new Date(m.createdAt).toDateString();
    if(d!==lastD){ frag.appendChild(mkDateEl(new Date(m.createdAt))); lastD=d; }
    frag.appendChild(mkMsgEl(m));
  });

  // Also fix date separator on what is now the "next" first message of old batch
  const firstExistingRow = wrap.querySelector('.row, .date-sep');
  topLoader.after(frag);

  // Restore scroll position so content doesn't jump
  requestAnimationFrame(()=>{
    const newScrollHeight=wrap.scrollHeight;
    wrap.scrollTop = prevScrollTop + (newScrollHeight - prevScrollHeight);
  });
}

// ════════════ RENDER ════════════
function renderInitialMessages(msgs){
  const wrap=document.getElementById('msgs');
  Array.from(wrap.children).forEach(c=>{
    if(!c.classList.contains('typing-row') && !c.classList.contains('top-loader')) c.remove();
  });
  let lastD=null;
  msgs.forEach(m=>{
    const d=new Date(m.createdAt).toDateString();
    if(d!==lastD){appendDate(new Date(m.createdAt));lastD=d;}
    appendMsg(m, false);
  });
  scrollBot(true);
}

function mkDateEl(d){
  const today=new Date().toDateString(),yest=new Date(Date.now()-86400000).toDateString();
  const lbl=d.toDateString()===today?'Today':d.toDateString()===yest?'Yesterday':d.toLocaleDateString('en-IN',{day:'numeric',month:'long',year:'numeric'});
  const div=document.createElement('div'); div.className='date-sep'; div.innerHTML=`<span>${lbl}</span>`;
  return div;
}
function appendDate(d){
  document.getElementById('msgs').insertBefore(mkDateEl(d), document.getElementById('typRow'));
}

function mkMsgEl(msg){
  const mine=msg.sender===ME;
  const row=document.createElement('div');
  row.className='row '+(mine?'out':'in');
  row.dataset.id=msg._id; row.dataset.date=new Date(msg.createdAt).toDateString();
  row.dataset.type=msg.type||'text'; row.dataset.content=msg.content||'';
  row.dataset.stk=msg.stickerUrl||''; row.dataset.sender=msg.sender;

  if(!mine){
    const av=document.createElement('div'); av.className='msg-av oth';
    const src=localStorage.getItem('av_'+OTHER);
    if(src) setAvImg(av,src); else av.textContent=OTHER_NAME[0];
    row.appendChild(av);
  }

  const bbl=document.createElement('div');
  if(msg.type==='sticker'){
    bbl.className='bbl stk';
    if(msg.replyTo?.sender) bbl.appendChild(mkRpBox(msg.replyTo));
    const img=document.createElement('img'); img.className='stk-img'; img.src=msg.stickerUrl; img.loading='lazy'; bbl.appendChild(img);
  } else {
    bbl.className='bbl';
    if(msg.replyTo?.sender) bbl.appendChild(mkRpBox(msg.replyTo));
    if(msg.type==='image'){
      const src=msg.fileData||msg.fileUrl||'';
      if(src){const img=document.createElement('img');img.className='msg-img';img.src=src;img.loading='lazy';img.onclick=e=>{e.stopPropagation();openImgV(src);};bbl.appendChild(img);}
      if(msg.content){const t=document.createElement('div');t.textContent=msg.content;t.style.whiteSpace='pre-wrap';bbl.appendChild(t);}
    } else if(msg.type==='file'){
      const src=msg.fileUrl||msg.fileData||'';
      const a=document.createElement('a'); a.className='file-row'; a.href=src; a.download=msg.fileName||'file'; a.target='_blank'; a.onclick=e=>e.stopPropagation();
      const ext=(msg.fileName||'').split('.').pop().toUpperCase()||'FILE';
      a.innerHTML=`<span class="file-ico">📄</span><div><div class="file-nm">${esc(msg.fileName||'File')}</div><div class="file-sz">${fmtSz(msg.fileSize)} · ${ext}</div></div>`;
      bbl.appendChild(a);
    } else {
      const t=document.createElement('div'); t.style.whiteSpace='pre-wrap'; t.textContent=msg.content||''; bbl.appendChild(t);
    }
    if(msg.reactions?.length){
      const rrow=document.createElement('div'); rrow.className='r-row';
      renderReactions(rrow,msg.reactions,msg._id); bbl.appendChild(rrow);
    }
    const meta=document.createElement('div'); meta.className='meta';
    const tm=document.createElement('span'); tm.className='meta-time'; tm.textContent=fmtTime(msg.createdAt); meta.appendChild(tm);
    if(mine){const tk=document.createElement('span');tk.className='meta-tick'+(msg.read?' rd':'');tk.textContent=msg.read?'✓✓':'✓';meta.appendChild(tk);}
    bbl.appendChild(meta);
  }
  row.appendChild(bbl);
  const arr=document.createElement('div'); arr.className='sw-arr'; arr.textContent='↩'; row.appendChild(arr);
  setupRowEvents(row,msg);
  return row;
}

function appendMsg(msg, isNew){
  const wrap=document.getElementById('msgs');
  const row=mkMsgEl(msg);
  wrap.insertBefore(row, document.getElementById('typRow'));
}

function mkRpBox(rp){
  const d=document.createElement('div'); d.className='rp-box';
  const name=rp.sender===ME?MY_NAME:OTHER_NAME;
  const txt=document.createElement('div'); txt.className='rp-txt';
  if(rp.type==='sticker'&&rp.stickerUrl){const img=document.createElement('img');img.className='rp-stk-th';img.src=rp.stickerUrl;txt.appendChild(img);txt.appendChild(document.createTextNode('Sticker'));}
  else{txt.textContent=rp.content||'Message';}
  d.innerHTML=`<div class="rp-name">${name}</div>`;
  d.appendChild(txt);
  d.onclick=e=>{e.stopPropagation();scrollToMsg(rp.id);};
  return d;
}

function renderReactions(container,reactions,msgId){
  container.innerHTML='';
  const map={};
  reactions.forEach(r=>{if(!r.emoji)return;if(!map[r.emoji])map[r.emoji]={count:0,byMe:false};map[r.emoji].count++;if(r.by===ME)map[r.emoji].byMe=true;});
  Object.entries(map).forEach(([emoji,{count,byMe}])=>{
    const chip=document.createElement('div'); chip.className='r-chip'+(byMe?' mine':'');
    chip.innerHTML=`<span>${emoji}</span>${count>1?`<span class="r-cnt">${count}</span>`:''}`;
    chip.onclick=e=>{e.stopPropagation();socket.emit('addReaction',{msgId,emoji:byMe?'':emoji,user:ME});};
    container.appendChild(chip);
  });
}

// ── SWIPE + LONG PRESS ──
function setupRowEvents(row,msg){
  let tx0=0,ty0=0,swiped=false,pressing=false,pressT=null;
  row.addEventListener('touchstart',e=>{
    tx0=e.touches[0].clientX;ty0=e.touches[0].clientY;swiped=false;pressing=true;
    pressT=setTimeout(()=>{if(pressing)showEmojiPicker(e.touches[0].clientX,e.touches[0].clientY,msg._id);},500);
  },{passive:true});
  row.addEventListener('touchmove',e=>{
    pressing=false;clearTimeout(pressT);
    const dx=e.touches[0].clientX-tx0,dy=Math.abs(e.touches[0].clientY-ty0);
    if(dy>18){row.style.transform='';return;}
    const dir=msg.sender===ME?-1:1,pull=dx*dir;
    if(pull>0&&pull<72){row.style.transform=`translateX(${dx}px)`;row.classList.add('sw');row.querySelector('.sw-arr').style.opacity=Math.min(pull/50,1);}
    if(pull>=55&&!swiped){swiped=true;setReply(msg);if(navigator.vibrate)navigator.vibrate(28);}
  },{passive:true});
  row.addEventListener('touchend',()=>{pressing=false;clearTimeout(pressT);row.style.transform='';row.classList.remove('sw');row.querySelector('.sw-arr').style.opacity=0;});
  row.addEventListener('contextmenu',e=>{e.preventDefault();showEmojiPicker(e.clientX,e.clientY,msg._id);});
}

