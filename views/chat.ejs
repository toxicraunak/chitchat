<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title><%= user === 'tanji' ? 'Hinata' : 'Tanji' %> — TanjiChat</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
:root{
  --bg:#0e1621;
  --header:#17212b;
  --msg-in:#182533;
  --msg-out:#2b5278;
  --accent:#2AABEE;
  --text:#e8eaed;
  --muted:#7d8b99;
  --border:rgba(255,255,255,0.07);
  --hover:rgba(255,255,255,0.05);
  --safe-top:env(safe-area-inset-top,0px);
  --safe-bot:env(safe-area-inset-bottom,0px);
}
html,body{height:100%;overflow:hidden;background:var(--bg);font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;color:var(--text);}

/* APP SHELL */
#app{display:flex;flex-direction:column;height:100dvh;height:100vh;position:fixed;inset:0;}

/* ── HEADER ── */
.hdr{
  background:var(--header);
  display:flex;align-items:center;gap:10px;
  padding:8px 12px;
  padding-top:calc(8px + var(--safe-top));
  border-bottom:1px solid var(--border);
  flex-shrink:0;z-index:30;
  min-height:56px;
}
.hdr-back{color:var(--accent);font-size:22px;padding:6px;border-radius:50%;text-decoration:none;display:flex;align-items:center;flex-shrink:0;}
.hdr-av{
  width:38px;height:38px;border-radius:50%;flex-shrink:0;
  background:linear-gradient(135deg,#2AABEE,#7B5EA7);
  display:flex;align-items:center;justify-content:center;
  font-size:16px;font-weight:700;color:#fff;cursor:pointer;
  position:relative;overflow:hidden;
  border:2px solid transparent;transition:border-color .2s;
}
.hdr-av img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;border-radius:50%;}
.hdr-av:active{border-color:var(--accent);}
.hdr-info{flex:1;min-width:0;}
.hdr-name{font-size:15px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.hdr-status{font-size:12px;color:var(--muted);}
.hdr-status.on{color:#4dce7a;}
.hdr-btn{width:40px;height:40px;border-radius:50%;border:none;background:transparent;color:var(--muted);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
.hdr-btn:active{background:var(--hover);}

/* ── MESSAGES ── */
#msgs{
  flex:1;overflow-y:auto;overflow-x:hidden;
  padding:10px 8px 8px;
  display:flex;flex-direction:column;
  scroll-behavior:smooth;
  -webkit-overflow-scrolling:touch;
  overscroll-behavior-y:contain;
  background:var(--bg);
}
#msgs::-webkit-scrollbar{display:none;}

/* DATE */
.date-sep{text-align:center;margin:10px 0;pointer-events:none;}
.date-sep span{background:rgba(0,0,0,.45);color:var(--muted);font-size:11px;padding:3px 12px;border-radius:20px;}

/* ROW */
.row{
  display:flex;align-items:flex-end;gap:6px;
  margin-bottom:1px;padding:2px 4px;border-radius:10px;
  position:relative;
  transition:background .15s,transform .15s;
  user-select:none;-webkit-user-select:none;
  touch-action:pan-y;
  will-change:transform;
}
.row.out{flex-direction:row-reverse;}
.row.highlight{background:rgba(42,171,238,.12);}
.row.swiping{transition:transform .05s;}

/* Swipe reply arrow */
.sw-arrow{
  position:absolute;top:50%;transform:translateY(-50%);
  color:var(--accent);font-size:18px;opacity:0;transition:opacity .15s;
  pointer-events:none;
}
.row.in .sw-arrow{left:44px;}
.row.out .sw-arrow{right:4px;}

/* MSG AVATAR */
.msg-av{
  width:26px;height:26px;border-radius:50%;flex-shrink:0;
  background:linear-gradient(135deg,#7B5EA7,#2AABEE);
  display:flex;align-items:center;justify-content:center;
  font-size:11px;font-weight:700;color:#fff;
  position:relative;overflow:hidden;align-self:flex-end;
}
.msg-av img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;border-radius:50%;}

/* BUBBLE */
.bbl{
  max-width:75%;min-width:52px;
  padding:7px 10px;border-radius:14px;
  font-size:14px;line-height:1.45;word-break:break-word;
  position:relative;
}
.row.in .bbl{background:var(--msg-in);border-bottom-left-radius:3px;}
.row.out .bbl{background:var(--msg-out);border-bottom-right-radius:3px;}
.bbl.stk{background:transparent!important;padding:2px;}

/* Reply inside bubble */
.rp-box{
  background:rgba(255,255,255,.07);border-left:3px solid var(--accent);
  border-radius:6px;padding:5px 8px;margin-bottom:6px;cursor:pointer;
}
.rp-box .rp-name{font-size:11px;color:var(--accent);font-weight:600;margin-bottom:2px;}
.rp-box .rp-txt{font-size:12px;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;display:flex;align-items:center;gap:5px;}
.rp-stk-th{width:26px;height:26px;object-fit:contain;border-radius:4px;}

/* Sticker */
.stk-img{width:130px;height:130px;object-fit:contain;display:block;border-radius:8px;}

/* Image */
.msg-img{max-width:240px;max-height:240px;object-fit:cover;border-radius:10px;display:block;cursor:pointer;margin-bottom:2px;}

/* File */
.file-row{display:flex;align-items:center;gap:8px;text-decoration:none;color:inherit;min-width:160px;}
.file-ico{font-size:26px;flex-shrink:0;}
.file-nm{font-size:13px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:160px;}
.file-sz{font-size:11px;color:var(--muted);margin-top:1px;}

/* Meta */
.meta{display:flex;align-items:center;gap:3px;justify-content:flex-end;margin-top:3px;}
.meta-time{font-size:10px;color:rgba(255,255,255,.35);}
.meta-tick{font-size:12px;color:rgba(255,255,255,.35);}
.meta-tick.rd{color:var(--accent);}

/* Typing */
.typing-row{display:none;align-items:center;gap:8px;padding:4px 4px 8px 40px;}
.typing-row.show{display:flex;}
.dots{display:flex;gap:4px;}
.dots span{width:7px;height:7px;border-radius:50%;background:var(--muted);animation:bop 1.2s infinite;}
.dots span:nth-child(2){animation-delay:.2s;}
.dots span:nth-child(3){animation-delay:.4s;}
@keyframes bop{0%,80%,100%{transform:scale(.75);opacity:.5}40%{transform:scale(1);opacity:1}}

/* ── REPLY BAR ── */
.rp-bar{
  display:none;background:var(--header);
  border-top:1px solid var(--border);
  padding:8px 12px;align-items:center;gap:10px;flex-shrink:0;
}
.rp-bar.show{display:flex;}
.rp-bar-info{flex:1;min-width:0;}
.rp-bar-name{font-size:12px;color:var(--accent);font-weight:600;}
.rp-bar-txt{font-size:13px;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;display:flex;align-items:center;gap:5px;}
.rp-bar-stk{width:28px;height:28px;object-fit:contain;border-radius:4px;}
.rp-close{background:none;border:none;color:var(--muted);font-size:20px;cursor:pointer;padding:4px;border-radius:50%;display:flex;align-items:center;justify-content:center;}

/* ── STICKER PANEL ── */
#stkPanel{
  display:none;background:var(--header);
  border-top:1px solid var(--border);
  max-height:240px;overflow-y:auto;padding:10px;flex-shrink:0;
  -webkit-overflow-scrolling:touch;
}
#stkPanel.show{display:block;}
#stkPanel::-webkit-scrollbar{display:none;}
.stk-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(72px,1fr));gap:8px;}
.stk-cell{aspect-ratio:1;border-radius:10px;background:rgba(255,255,255,.04);cursor:pointer;display:flex;align-items:center;justify-content:center;overflow:hidden;}
.stk-cell:active{transform:scale(.92);}
.stk-cell img{width:100%;height:100%;object-fit:contain;padding:4px;}

/* ── INPUT AREA ── */
.inp-area{
  background:var(--header);
  border-top:1px solid var(--border);
  padding:6px 8px;
  padding-bottom:calc(6px + var(--safe-bot));
  display:flex;align-items:flex-end;gap:6px;flex-shrink:0;
}
.inp-ico{width:40px;height:40px;border-radius:50%;border:none;background:transparent;color:var(--muted);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;}
.inp-ico:active{background:var(--hover);}
.inp-box{
  flex:1;background:rgba(255,255,255,.07);border:1px solid var(--border);
  border-radius:20px;padding:9px 14px;color:var(--text);font-size:15px;
  outline:none;resize:none;max-height:120px;min-height:40px;
  line-height:1.45;font-family:inherit;
  -webkit-appearance:none;
}
.inp-box:focus{border-color:rgba(42,171,238,.4);}
.inp-box::placeholder{color:var(--muted);}
.send-btn{width:40px;height:40px;border-radius:50%;border:none;background:var(--accent);color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
.send-btn:active{transform:scale(.93);}

/* ── MODALS ── */
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:200;align-items:flex-end;justify-content:center;}
.overlay.show{display:flex;}
.sheet{
  background:#17212b;border-radius:20px 20px 0 0;
  padding:20px;width:100%;max-width:480px;
  padding-bottom:calc(20px + var(--safe-bot));
}
.sheet h3{font-size:16px;font-weight:700;margin-bottom:16px;text-align:center;}
.sheet-av{
  width:72px;height:72px;border-radius:50%;margin:0 auto 16px;
  background:linear-gradient(135deg,#2AABEE,#7B5EA7);
  display:flex;align-items:center;justify-content:center;
  font-size:28px;font-weight:700;color:#fff;
  position:relative;overflow:hidden;
}
.sheet-av img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;}
.sh-btn{display:block;width:100%;padding:13px;border-radius:12px;border:none;font-size:15px;font-weight:600;cursor:pointer;margin-bottom:10px;transition:all .2s;}
.sh-btn.pri{background:var(--accent);color:#fff;}
.sh-btn.sec{background:rgba(255,255,255,.07);color:var(--text);}
.sh-btn:active{opacity:.8;}

/* Image viewer */
#imgViewer{display:none;position:fixed;inset:0;background:rgba(0,0,0,.95);z-index:300;align-items:center;justify-content:center;flex-direction:column;}
#imgViewer.show{display:flex;}
#imgViewer img{max-width:95vw;max-height:85vh;object-fit:contain;border-radius:8px;}
.iv-close{position:absolute;top:calc(16px + var(--safe-top));right:16px;color:#fff;font-size:28px;cursor:pointer;width:40px;height:40px;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.5);border-radius:50%;}

/* Context menu */
#ctx{display:none;position:fixed;z-index:400;background:#242f3d;border-radius:12px;overflow:hidden;min-width:160px;box-shadow:0 8px 32px rgba(0,0,0,.6);}
#ctx.show{display:block;}
.ctx-item{padding:13px 16px;font-size:14px;cursor:pointer;display:flex;align-items:center;gap:10px;}
.ctx-item:active{background:var(--hover);}
.ctx-item.danger{color:#ff6b6b;}

/* Upload progress */
.up-toast{
  position:fixed;bottom:80px;left:50%;transform:translateX(-50%);
  background:#242f3d;border-radius:10px;padding:10px 16px;
  font-size:13px;color:var(--text);z-index:500;
  display:none;align-items:center;gap:10px;white-space:nowrap;
  box-shadow:0 4px 20px rgba(0,0,0,.5);
}
.up-toast.show{display:flex;}
</style>
</head>
<body>
<input type="file" id="avInput" accept="image/*" style="display:none">
<input type="file" id="fileInput" accept="*/*" style="display:none">

<div id="app">

  <!-- HEADER -->
  <div class="hdr">
    <a href="/" class="hdr-back">‹</a>
    <div class="hdr-av" id="otherAv" onclick="openAvSheet()">
      <% if(otherProfile.avatar){%><img src="<%=otherProfile.avatar%>" alt="av"><%}else{%><%=user==='tanji'?'H':'T'%><%}%>
    </div>
    <div class="hdr-info">
      <div class="hdr-name"><%=user==='tanji'?'Hinata':'Tanji'%></div>
      <div class="hdr-status" id="statusTxt">last seen recently</div>
    </div>
    <button class="hdr-btn" onclick="triggerCall()" title="Call">📞</button>
    <button class="hdr-btn" onclick="openAvSheet()" title="DP">👤</button>
  </div>

  <!-- MESSAGES -->
  <div id="msgs">
    <div class="typing-row" id="typRow">
      <div class="dots"><span></span><span></span><span></span></div>
      <span id="typName" style="font-size:12px;color:var(--muted)"></span>
    </div>
  </div>

  <!-- REPLY BAR -->
  <div class="rp-bar" id="rpBar">
    <span style="color:var(--accent);font-size:18px;flex-shrink:0">↩</span>
    <div class="rp-bar-info">
      <div class="rp-bar-name" id="rpName"></div>
      <div class="rp-bar-txt" id="rpTxt"></div>
    </div>
    <button class="rp-close" onclick="clearReply()">✕</button>
  </div>

  <!-- STICKER PANEL -->
  <div id="stkPanel">
    <div class="stk-grid" id="stkGrid"></div>
  </div>

  <!-- INPUT AREA -->
  <div class="inp-area">
    <button class="inp-ico" onclick="document.getElementById('fileInput').click()">📎</button>
    <textarea class="inp-box" id="msgBox" placeholder="Message..." rows="1"></textarea>
    <button class="inp-ico" id="stkBtn" onclick="toggleStk()">😊</button>
    <button class="send-btn" onclick="doSend()">➤</button>
  </div>

</div><!-- /app -->

<!-- AVATAR SHEET -->
<div class="overlay" id="avSheet" onclick="closeSheet(event)">
  <div class="sheet">
    <h3>Your Photo</h3>
    <div class="sheet-av" id="shAvPrev">
      <%=user==='tanji'?'T':'H'%>
    </div>
    <button class="sh-btn pri" onclick="document.getElementById('avInput').click()">📷 Change Photo</button>
    <button class="sh-btn sec" onclick="document.getElementById('avSheet').classList.remove('show')">Cancel</button>
  </div>
</div>

<!-- IMAGE VIEWER -->
<div id="imgViewer" onclick="closeImgV()">
  <span class="iv-close">✕</span>
  <img id="ivImg" src="" alt="img">
</div>

<!-- CONTEXT MENU -->
<div id="ctx">
  <div class="ctx-item" onclick="ctxReply()">↩ Reply</div>
  <div class="ctx-item danger" onclick="ctxDelete()">🗑 Delete</div>
</div>

<!-- Upload toast -->
<div class="up-toast" id="upToast">
  <span>⏳</span><span id="upMsg">Uploading...</span>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
const ME = '<%=user%>';
const OTHER = ME==='tanji'?'hinata':'tanji';
const MY_NAME = ME==='tanji'?'Tanji':'Hinata';
const OTHER_NAME = ME==='tanji'?'Hinata':'Tanji';

let socket, replyData=null, ctxMsg=null;
let typTimer=null, isTyp=false;
let stickers=[];

// ── SOCKET ──
socket = io();
socket.emit('join', ME);

socket.on('history', msgs=>{
  const wrap = document.getElementById('msgs');
  // Clear all but typing row
  wrap.innerHTML = '<div class="typing-row" id="typRow"><div class="dots"><span></span><span></span><span></span></div><span id="typName" style="font-size:12px;color:var(--muted)"></span></div>';
  let lastD = null;
  msgs.forEach(m=>{
    const d = new Date(m.createdAt).toDateString();
    if(d!==lastD){ appendDate(new Date(m.createdAt)); lastD=d; }
    appendMsg(m);
  });
  scrollBot();
  syncAvatars();
});

socket.on('newMessage', msg=>{
  const wrap = document.getElementById('msgs');
  const rows = wrap.querySelectorAll('.row');
  if(rows.length>0){
    const lastD = rows[rows.length-1].dataset.date;
    const newD = new Date(msg.createdAt).toDateString();
    if(lastD!==newD) appendDate(new Date(msg.createdAt));
  }
  appendMsg(msg);
  scrollBot();
});

socket.on('typing', d=>{ if(d.sender!==ME){ document.getElementById('typName').textContent=OTHER_NAME; document.getElementById('typRow').classList.add('show'); scrollBot(); }});
socket.on('stopTyping', ()=> document.getElementById('typRow').classList.remove('show'));

socket.on('onlineStatus', status=>{
  const el=document.getElementById('statusTxt');
  if(status[OTHER]){el.textContent='online';el.className='hdr-status on';}
  else{el.textContent='last seen recently';el.className='hdr-status';}
});

socket.on('avatarUpdate', ({user,avatar})=>{
  if(user===OTHER){
    updateAv('otherAv', avatar);
    localStorage.setItem('av_'+OTHER, avatar);
    document.querySelectorAll('.msg-av.oth').forEach(a=>{
      let img=a.querySelector('img'); if(!img){img=document.createElement('img');a.appendChild(img);a.childNodes[0].nodeType===3&&(a.childNodes[0].remove());}
      img.src=avatar;
    });
  } else {
    localStorage.setItem('av_'+ME, avatar);
    const prev=document.getElementById('shAvPrev');
    let img=prev.querySelector('img'); if(!img){prev.textContent='';img=document.createElement('img');prev.appendChild(img);}
    img.src=avatar;
  }
});

socket.on('messagesRead', ({by})=>{
  if(by===OTHER) document.querySelectorAll('.row.out .meta-tick').forEach(el=>{el.classList.add('rd');el.textContent='✓✓';});
});

// ── RENDER MSG ──
function appendMsg(msg){
  const wrap=document.getElementById('msgs');
  const mine=msg.sender===ME;
  const row=document.createElement('div');
  row.className='row '+(mine?'out':'in');
  row.dataset.id=msg._id; row.dataset.date=new Date(msg.createdAt).toDateString();
  row.dataset.type=msg.type||'text'; row.dataset.content=msg.content||'';
  row.dataset.stk=msg.stickerUrl||''; row.dataset.sender=msg.sender;

  // Avatar (incoming only)
  if(!mine){
    const av=document.createElement('div');
    av.className='msg-av oth';
    const stored=localStorage.getItem('av_'+OTHER);
    if(stored){ const img=document.createElement('img'); img.src=stored; av.appendChild(img); }
    else{ av.textContent=OTHER_NAME[0]; }
    row.appendChild(av);
  }

  // Bubble
  const bbl=document.createElement('div');
  if(msg.type==='sticker'){
    bbl.className='bbl stk';
    if(msg.replyTo?.sender) bbl.appendChild(mkReplyBox(msg.replyTo));
    const img=document.createElement('img'); img.className='stk-img'; img.src=msg.stickerUrl; bbl.appendChild(img);
  } else {
    bbl.className='bbl';
    if(msg.replyTo?.sender) bbl.appendChild(mkReplyBox(msg.replyTo));
    if(msg.type==='image'){
      const img=document.createElement('img'); img.className='msg-img'; img.src=msg.fileUrl;
      img.onclick=e=>{e.stopPropagation();openImgV(msg.fileUrl);}; bbl.appendChild(img);
      if(msg.content){const t=document.createElement('div');t.textContent=msg.content;t.style.whiteSpace='pre-wrap';bbl.appendChild(t);}
    } else if(msg.type==='file'){
      const a=document.createElement('a'); a.className='file-row'; a.href=msg.fileUrl; a.download=msg.fileName; a.target='_blank'; a.onclick=e=>e.stopPropagation();
      const ext=(msg.fileName||'').split('.').pop().toUpperCase();
      a.innerHTML=`<span class="file-ico">📄</span><div><div class="file-nm">${esc(msg.fileName)}</div><div class="file-sz">${fmtSz(msg.fileSize)} · ${ext}</div></div>`;
      bbl.appendChild(a);
    } else {
      const t=document.createElement('div'); t.style.whiteSpace='pre-wrap'; t.textContent=msg.content; bbl.appendChild(t);
    }
    const meta=document.createElement('div'); meta.className='meta';
    const tm=document.createElement('span'); tm.className='meta-time'; tm.textContent=fmtTime(msg.createdAt); meta.appendChild(tm);
    if(mine){const tk=document.createElement('span');tk.className='meta-tick'+(msg.read?' rd':'');tk.textContent=msg.read?'✓✓':'✓';meta.appendChild(tk);}
    bbl.appendChild(meta);
  }
  row.appendChild(bbl);

  // Swipe arrow
  const arr=document.createElement('div'); arr.className='sw-arrow'; arr.textContent='↩'; row.appendChild(arr);

  // Events
  setupEvents(row, msg);
  wrap.insertBefore(row, document.getElementById('typRow'));
}

function mkReplyBox(rp){
  const d=document.createElement('div'); d.className='rp-box';
  const name=rp.sender===ME?MY_NAME:OTHER_NAME;
  const txt=document.createElement('div'); txt.className='rp-txt';
  if(rp.type==='sticker'&&rp.stickerUrl){
    const img=document.createElement('img'); img.className='rp-stk-th'; img.src=rp.stickerUrl; txt.appendChild(img);
    txt.appendChild(document.createTextNode('Sticker'));
  } else { txt.textContent=rp.content||'Message'; }
  d.innerHTML=`<div class="rp-name">${name}</div>`;
  d.appendChild(txt);
  d.onclick=e=>{e.stopPropagation();scrollTo(rp.id);};
  return d;
}

// ── SWIPE TO REPLY (touch) ──
function setupEvents(row, msg){
  let tx0=0, ty0=0, swiped=false, pressing=false, pressT=null;

  row.addEventListener('touchstart',e=>{
    tx0=e.touches[0].clientX; ty0=e.touches[0].clientY; swiped=false;
    pressing=true;
    pressT=setTimeout(()=>{ if(pressing) showCtx(e.touches[0].clientX,e.touches[0].clientY,msg); },550);
  },{passive:true});

  row.addEventListener('touchmove',e=>{
    pressing=false; clearTimeout(pressT);
    const dx=e.touches[0].clientX-tx0;
    const dy=Math.abs(e.touches[0].clientY-ty0);
    if(dy>20){row.style.transform='';return;}
    const dir=msg.sender===ME?-1:1;
    const pull=dx*dir;
    if(pull>0&&pull<70){
      row.style.transform=`translateX(${dx}px)`;
      row.classList.add('swiping');
      row.querySelector('.sw-arrow').style.opacity=Math.min(pull/50,1);
    }
    if(pull>=55&&!swiped){
      swiped=true;
      setReply(msg);
      if(navigator.vibrate) navigator.vibrate(30);
    }
  },{passive:true});

  row.addEventListener('touchend',()=>{
    pressing=false; clearTimeout(pressT);
    row.style.transform=''; row.classList.remove('swiping');
    row.querySelector('.sw-arrow').style.opacity=0;
  });

  row.addEventListener('contextmenu',e=>{e.preventDefault();showCtx(e.clientX,e.clientY,msg);});
}

// ── CONTEXT MENU ──
function showCtx(x,y,msg){
  ctxMsg=msg;
  const m=document.getElementById('ctx');
  m.style.left=Math.min(x,window.innerWidth-170)+'px';
  m.style.top=Math.min(y,window.innerHeight-110)+'px';
  m.classList.add('show');
}
function ctxReply(){ if(ctxMsg) setReply(ctxMsg); document.getElementById('ctx').classList.remove('show'); }
function ctxDelete(){
  if(ctxMsg){ const el=document.querySelector(`[data-id="${ctxMsg._id}"]`); if(el)el.remove(); }
  document.getElementById('ctx').classList.remove('show');
}
document.addEventListener('click',()=>document.getElementById('ctx').classList.remove('show'));

// ── REPLY ──
function setReply(msg){
  replyData=msg;
  document.getElementById('rpName').textContent=msg.sender===ME?MY_NAME:OTHER_NAME;
  const txt=document.getElementById('rpTxt'); txt.innerHTML='';
  if(msg.type==='sticker'&&msg.stickerUrl){
    const img=document.createElement('img'); img.className='rp-bar-stk'; img.src=msg.stickerUrl; txt.appendChild(img);
    txt.appendChild(document.createTextNode('Sticker'));
  } else { txt.textContent=msg.content||msg.fileName||'Message'; }
  document.getElementById('rpBar').classList.add('show');
  document.getElementById('msgBox').focus();
  document.getElementById('stkPanel').classList.remove('show');
}
function clearReply(){ replyData=null; document.getElementById('rpBar').classList.remove('show'); }
function mkRpPayload(m){ return {id:m._id,sender:m.sender,content:m.content||'',type:m.type||'text',stickerUrl:m.stickerUrl||''}; }

// ── SEND ──
function doSend(){
  const box=document.getElementById('msgBox');
  const txt=box.value.trim(); if(!txt) return;
  const pl={sender:ME,type:'text',content:txt};
  if(replyData) pl.replyTo=mkRpPayload(replyData);
  socket.emit('sendMessage',pl);
  box.value=''; box.style.height='auto'; clearReply(); stopTyp();
}

// ── TYPING ──
const msgBox=document.getElementById('msgBox');
msgBox.addEventListener('input',()=>{
  msgBox.style.height='auto';
  msgBox.style.height=Math.min(msgBox.scrollHeight,120)+'px';
  if(!isTyp){isTyp=true;socket.emit('typing',{sender:ME});}
  clearTimeout(typTimer); typTimer=setTimeout(stopTyp,2000);
});
msgBox.addEventListener('keydown',e=>{if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();doSend();}});
function stopTyp(){if(isTyp){isTyp=false;socket.emit('stopTyping',{sender:ME});}clearTimeout(typTimer);}

// ── FILE UPLOAD ──
document.getElementById('fileInput').addEventListener('change',async e=>{
  const file=e.target.files[0]; if(!file) return;
  showToast('Uploading '+file.name+'...');
  const fd=new FormData(); fd.append('file',file);
  try{
    const res=await fetch('/api/upload',{method:'POST',body:fd});
    const d=await res.json();
    const pl={sender:ME,type:d.isImage?'image':'file',fileUrl:d.url,fileName:d.name,fileSize:d.size};
    if(replyData) pl.replyTo=mkRpPayload(replyData);
    socket.emit('sendMessage',pl); clearReply();
  }catch(err){alert('Upload failed');}
  hideToast(); e.target.value='';
});

// ── STICKERS ──
async function loadStk(){
  const res=await fetch('/api/stickers'); stickers=await res.json();
  const grid=document.getElementById('stkGrid'); grid.innerHTML='';
  if(!stickers.length){grid.innerHTML='<div style="color:var(--muted);font-size:13px;text-align:center;padding:20px;grid-column:1/-1">No stickers yet!<br>Admin se add karwao 😊</div>';return;}
  stickers.forEach(s=>{
    const cell=document.createElement('div'); cell.className='stk-cell';
    cell.innerHTML=`<img src="${esc(s.url)}" loading="lazy" alt="${esc(s.name)}">`;
    cell.onclick=()=>sendStk(s); grid.appendChild(cell);
  });
}
loadStk();

function toggleStk(){
  document.getElementById('stkPanel').classList.toggle('show');
  document.getElementById('msgBox').blur();
}
function sendStk(s){
  const pl={sender:ME,type:'sticker',stickerUrl:s.url};
  if(replyData) pl.replyTo=mkRpPayload(replyData);
  socket.emit('sendMessage',pl); clearReply();
  document.getElementById('stkPanel').classList.remove('show');
}

// ── CALL ──
function triggerCall(){
  socket.emit('callOnline',{caller:ME});
  showToast('📞 Online status sent!');
  setTimeout(hideToast,2500);
}

// ── AVATAR ──
function openAvSheet(){ document.getElementById('avSheet').classList.add('show'); syncMySheetAv(); }
function closeSheet(e){ if(e.target===document.getElementById('avSheet')) document.getElementById('avSheet').classList.remove('show'); }

function syncMySheetAv(){
  const prev=document.getElementById('shAvPrev');
  const stored=localStorage.getItem('av_'+ME);
  if(stored){ let img=prev.querySelector('img'); if(!img){prev.textContent='';img=document.createElement('img');prev.appendChild(img);} img.src=stored; }
}

document.getElementById('avInput').addEventListener('change',async e=>{
  const file=e.target.files[0]; if(!file) return;
  showToast('Uploading photo...');
  const fd=new FormData(); fd.append('avatar',file);
  try{
    const res=await fetch('/api/avatar/'+ME,{method:'POST',body:fd});
    const d=await res.json();
    if(d.avatar){ localStorage.setItem('av_'+ME,d.avatar); syncMySheetAv(); }
  }catch(err){alert('Upload failed');}
  hideToast(); document.getElementById('avSheet').classList.remove('show'); e.target.value='';
});

function updateAv(id,src){
  const el=document.getElementById(id); if(!el) return;
  let img=el.querySelector('img'); if(!img){img=document.createElement('img'); el.appendChild(img); if(el.firstChild&&el.firstChild.nodeType===3)el.firstChild.remove();}
  img.src=src;
}

function syncAvatars(){
  fetch('/api/profile/'+OTHER).then(r=>r.json()).then(p=>{
    if(p.avatar){ localStorage.setItem('av_'+OTHER,p.avatar); updateAv('otherAv',p.avatar);
      document.querySelectorAll('.msg-av.oth').forEach(a=>{ let img=a.querySelector('img'); if(!img){img=document.createElement('img');a.appendChild(img);try{a.childNodes[0].nodeType===3&&a.childNodes[0].remove();}catch(e){}} img.src=p.avatar; });
    }
  });
  fetch('/api/profile/'+ME).then(r=>r.json()).then(p=>{
    if(p.avatar){ localStorage.setItem('av_'+ME,p.avatar); syncMySheetAv(); }
  });
}

// ── UTILS ──
function scrollBot(){ const w=document.getElementById('msgs'); w.scrollTop=w.scrollHeight; }
function scrollTo(id){ const el=document.querySelector(`[data-id="${id}"]`); if(el){el.scrollIntoView({behavior:'smooth',block:'center'});el.classList.add('highlight');setTimeout(()=>el.classList.remove('highlight'),1200);} }
function fmtTime(ts){ const d=new Date(ts); return d.getHours().toString().padStart(2,'0')+':'+d.getMinutes().toString().padStart(2,'0'); }
function fmtSz(b){ if(!b)return'0B'; if(b<1024)return b+'B'; if(b<1048576)return(b/1024).toFixed(1)+'KB'; return(b/1048576).toFixed(1)+'MB'; }
function esc(s){ return(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function appendDate(d){
  const wrap=document.getElementById('msgs');
  const today=new Date().toDateString(), yest=new Date(Date.now()-86400000).toDateString();
  let lbl=d.toDateString()===today?'Today':d.toDateString()===yest?'Yesterday':d.toLocaleDateString('en-US',{day:'numeric',month:'long',year:'numeric'});
  const div=document.createElement('div'); div.className='date-sep'; div.innerHTML=`<span>${lbl}</span>`;
  wrap.insertBefore(div, document.getElementById('typRow'));
}
function showToast(msg){ const t=document.getElementById('upToast'); document.getElementById('upMsg').textContent=msg; t.classList.add('show'); }
function hideToast(){ document.getElementById('upToast').classList.remove('show'); }
function openImgV(src){ document.getElementById('ivImg').src=src; document.getElementById('imgViewer').classList.add('show'); }
function closeImgV(){ document.getElementById('imgViewer').classList.remove('show'); }

// Close sticker on outside tap
document.getElementById('msgs').addEventListener('click',()=> document.getElementById('stkPanel').classList.remove('show'));
document.getElementById('msgBox').addEventListener('focus',()=> document.getElementById('stkPanel').classList.remove('show'));

// Keyboard resize fix for mobile
if(window.visualViewport){
  window.visualViewport.addEventListener('resize',()=>{
    document.getElementById('app').style.height=window.visualViewport.height+'px';
    scrollBot();
  });
}
</script>
</body>
</html>
