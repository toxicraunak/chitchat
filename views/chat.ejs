});

// ── UTILS ──
function scrollBot(instant){
  const w=document.getElementById('msgs');
  if(instant){w.style.scrollBehavior='auto';w.scrollTop=w.scrollHeight;w.style.scrollBehavior='';}
  else{w.scrollTop=w.scrollHeight;}
}
function scrollToMsg(id){const el=document.querySelector(`[data-id="${id}"]`);if(el){el.scrollIntoView({behavior:'smooth',block:'center'});el.classList.add('hl');setTimeout(()=>el.classList.remove('hl'),1200);}}
function fmtTime(ts){const d=new Date(ts);return d.getHours().toString().padStart(2,'0')+':'+d.getMinutes().toString().padStart(2,'0');}
function fmtSz(b){if(!b)return'0B';if(b<1024)return b+'B';if(b<1048576)return(b/1024).toFixed(1)+'KB';return(b/1048576).toFixed(1)+'MB';}
function esc(s){return(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}

let toastTimer=null;
function showToast(msg,dur){clearTimeout(toastTimer);document.getElementById('toastMsg').textContent=msg;document.getElementById('toast').classList.add('show');if(dur)toastTimer=setTimeout(hideToast,dur);}
function hideToast(){clearTimeout(toastTimer);document.getElementById('toast').classList.remove('show');}
function openImgV(src){document.getElementById('ivImg').src=src;document.getElementById('imgV').classList.add('show');}
function closeImgV(){document.getElementById('imgV').classList.remove('show');}

document.getElementById('msgs').addEventListener('click',()=>document.getElementById('stkPanel').classList.remove('show'));
document.getElementById('msgBox').addEventListener('focus',()=>document.getElementById('stkPanel').classList.remove('show'));

if(window.visualViewport){
  window.visualViewport.addEventListener('resize',()=>{
    document.getElementById('app').style.height=window.visualViewport.height+'px';
    scrollBot();
  });
}
</script>
</body>
</html>
