// ── REPLY ──
function setReply(msg){
  replyData=msg;
  document.getElementById('rpName').textContent=msg.sender===ME?MY_NAME:OTHER_NAME;
  const txt=document.getElementById('rpTxt'); txt.innerHTML='';
  if(msg.type==='sticker'&&msg.stickerUrl){const img=document.createElement('img');img.className='rp-bar-stk';img.src=msg.stickerUrl;txt.appendChild(img);txt.appendChild(document.createTextNode('Sticker'));}
  else{txt.textContent=msg.content||msg.fileName||'Message';}
  document.getElementById('rpBar').classList.add('show');
  document.getElementById('stkPanel').classList.remove('show');
  document.getElementById('msgBox').focus();
}
function clearReply(){replyData=null;document.getElementById('rpBar').classList.remove('show');}
function mkRp(m){return{id:m._id,sender:m.sender,content:m.content||'',type:m.type||'text',stickerUrl:m.stickerUrl||''};}

// ── SEND ──
function doSend(){
  const box=document.getElementById('msgBox');
  const txt=box.value.trim(); if(!txt) return;
  const pl={sender:ME,type:'text',content:txt};
  if(replyData) pl.replyTo=mkRp(replyData);
  socket.emit('sendMessage',pl);
  box.value=''; box.style.height='auto'; clearReply(); stopTyp();
}

const msgBox=document.getElementById('msgBox');
msgBox.addEventListener('input',()=>{
  msgBox.style.height='auto'; msgBox.style.height=Math.min(msgBox.scrollHeight,120)+'px';
  if(!isTyp){isTyp=true;socket?.emit('typing',{sender:ME});}
  clearTimeout(typTimer); typTimer=setTimeout(stopTyp,2000);
});
msgBox.addEventListener('keydown',e=>{if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();doSend();}});
function stopTyp(){if(isTyp){isTyp=false;socket?.emit('stopTyping',{sender:ME});}clearTimeout(typTimer);}

// ── FILE ──
document.getElementById('fileInput').addEventListener('change',async e=>{
  const file=e.target.files[0]; if(!file) return;
  showToast('⏳ Uploading...');
  const fd=new FormData(); fd.append('file',file);
  try{
    const res=await fetch('/api/upload',{method:'POST',body:fd});
    const d=await res.json();
    const pl={sender:ME};
    if(d.isImage){pl.type='image';pl.fileData=d.dataUri;pl.fileName=d.name;pl.fileSize=d.size;}
    else{pl.type='file';pl.fileUrl=d.url;pl.fileName=d.name;pl.fileSize=d.size;}
    if(replyData) pl.replyTo=mkRp(replyData);
    socket.emit('sendMessage',pl); clearReply();
    hideToast();
  }catch(err){showToast('❌ Upload failed',3000);}
  e.target.value='';
});

// ════════════ LAZY STICKER PACKS ════════════
// Step 1: load lightweight pack list (icons only) — fast
async function loadStickerPackList(){
  try{
    const res=await fetch('/api/sticker-packs');
    lazyPacks=await res.json();
    buildStickerTabs();
  }catch(e){console.error('pack list load failed',e);}
}
loadStickerPackList();

function buildStickerTabs(){
  const tabs=document.getElementById('stkTabs'); tabs.innerHTML='';
  if(!lazyPacks.length){
    document.getElementById('stkGrid').innerHTML='<div class="stk-empty">No stickers yet!<br>Admin se .wastickers upload karwao 😊</div>';
    return;
  }
  lazyPacks.forEach((pack,i)=>{
    const tab=document.createElement('div'); tab.className='stk-tab'+(i===0?' active':''); tab.dataset.i=i;
    if(pack.icon){const img=document.createElement('img');img.src=pack.icon;img.loading='lazy';tab.appendChild(img);}
    else tab.textContent='😊';
    tab.onclick=()=>switchPack(i); tabs.appendChild(tab);
  });
}

// Step 2: only fetch sticker DATA for a pack when user actually opens it
async function switchPack(i){
  activePack=i;
  document.querySelectorAll('.stk-tab').forEach((t,j)=>t.classList.toggle('active',j===i));
  await showPack(i);
}

async function showPack(i){
  const grid=document.getElementById('stkGrid');
  const pack=lazyPacks[i]; if(!pack) return;

  // Already cached? render immediately
  if(packStickerCache[pack._id]){
    renderStickerGrid(packStickerCache[pack._id]);
    return;
  }

  // Show loading spinner, fetch only this pack's stickers
  grid.innerHTML='<div class="stk-loading"><div class="mini-spin"></div></div>';
  try{
    const res=await fetch(`/api/sticker-packs/${pack._id}/stickers`);
    const stickers=await res.json();
    packStickerCache[pack._id]=stickers;
    // Only render if user hasn't switched to another tab meanwhile
    if(lazyPacks[activePack]?._id===pack._id) renderStickerGrid(stickers);
  }catch(e){
    grid.innerHTML='<div class="stk-empty">Failed to load stickers</div>';
  }
}

function renderStickerGrid(stickers){
  const grid=document.getElementById('stkGrid'); grid.innerHTML='';
  if(!stickers.length){grid.innerHTML='<div class="stk-empty">Empty pack</div>';return;}
  stickers.forEach(s=>{
    const cell=document.createElement('div'); cell.className='stk-cell';
    const img=document.createElement('img'); img.src=s.data; img.loading='lazy'; cell.appendChild(img);
    cell.onclick=()=>sendStk(s.data); grid.appendChild(cell);
  });
}

function toggleStk(){
  const p=document.getElementById('stkPanel');
  const opening=!p.classList.contains('show');
  p.classList.toggle('show');
  if(opening){
    document.getElementById('msgBox').blur();
    // Load first pack's stickers on first open
    if(lazyPacks.length && !packStickerCache[lazyPacks[0]._id]) showPack(0);
    else if(lazyPacks.length) renderStickerGrid(packStickerCache[lazyPacks[activePack]._id]||[]);
  }
}
function sendStk(dataUri){
  const pl={sender:ME,type:'sticker',stickerUrl:dataUri};
  if(replyData) pl.replyTo=mkRp(replyData);
  socket.emit('sendMessage',pl); clearReply();
  document.getElementById('stkPanel').classList.remove('show');
}

