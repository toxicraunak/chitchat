<!-- THEME PICKER -->
<div id="themePicker" onclick="closeThemeOutside(event)">
  <div class="theme-sheet">
    <h3>🎨 Chat Theme</h3>
    <div class="theme-grid" id="themeGrid">
      <div class="theme-swatch th-wp-1" onclick="setTheme('dark','linear-gradient(135deg,#1a1a2e,#16213e,#0f3460)')" data-id="dark"><span>Dark Blue</span></div>
      <div class="theme-swatch th-wp-2" onclick="setTheme('ocean','linear-gradient(135deg,#0d1b2a,#1b2838,#2a475e)')" data-id="ocean"><span>Ocean</span></div>
      <div class="theme-swatch th-wp-3" onclick="setTheme('purple','linear-gradient(135deg,#1a0d2e,#2d1b4e,#1a0d3e)')" data-id="purple"><span>Purple</span></div>
      <div class="theme-swatch th-wp-4" onclick="setTheme('green','linear-gradient(135deg,#0d2818,#1a4228,#0d3818)')" data-id="green"><span>Forest</span></div>
      <div class="theme-swatch" style="background:linear-gradient(135deg,#1f0d1a,#3a1530)" onclick="setTheme('pink','linear-gradient(135deg,#1f0d1a,#3a1530)')" data-id="pink"><span>Rose</span></div>
      <div class="theme-swatch" style="background:linear-gradient(135deg,#1f1008,#3a2010)" onclick="setTheme('sunset','linear-gradient(135deg,#1f1008,#3a2010)')" data-id="sunset"><span>Sunset</span></div>
      <div class="theme-swatch" style="background:linear-gradient(135deg,#1a0808,#350f0f)" onclick="setTheme('cherry','linear-gradient(135deg,#1a0808,#350f0f)')" data-id="cherry"><span>Cherry</span></div>
      <div class="theme-swatch" style="background:#0a0f14" onclick="setTheme('night','none')" data-id="night"><span>Night</span></div>
    </div>
    <button class="theme-close" onclick="closeTheme()">Close</button>
  </div>
</div>

<!-- AVATAR SHEET -->
<div class="overlay" id="avSheet" onclick="closeSheet(event)">
  <div class="sheet">
    <h3>Your Photo</h3>
    <div class="sheet-av" id="shAvPrev"><%=user==='tanji'?'T':'H'%></div>
    <button class="sh-btn pri" onclick="document.getElementById('avInput').click()">📷 Change Photo</button>
    <button class="sh-btn sec" onclick="document.getElementById('avSheet').classList.remove('show')">Cancel</button>
  </div>
</div>

<!-- IMAGE VIEWER -->
<div id="imgV" onclick="closeImgV()">
  <span class="iv-close">✕</span>
  <img id="ivImg" src="" alt="">
</div>

<!-- TOAST -->
<div class="toast" id="toast"><span id="toastMsg"></span></div>

<script src="/socket.io/socket.io.js"></script>
<script>
const ME = '<%=user%>';
const OTHER = ME==='tanji'?'hinata':'tanji';
const MY_NAME = ME==='tanji'?'Tanji':'Hinata';
const OTHER_NAME = ME==='tanji'?'Hinata':'Tanji';

let socket, replyData=null, pickerMsgId=null;
let typTimer=null, isTyp=false;
let stickerPacks=[], activePack=0;

// ── INIT SOCKET ──
socket = io();
socket.emit('join', ME);

socket.on('history', msgs=>{
  const wrap=document.getElementById('msgs');
  wrap.innerHTML='<div class="typing-row" id="typRow"><div class="dots"><span></span><span></span><span></span></div><span id="typName" style="font-size:12px;color:var(--muted)"></span></div>';
  let lastD=null;
  msgs.forEach(m=>{
    const d=new Date(m.createdAt).toDateString();
    if(d!==lastD){appendDate(new Date(m.createdAt));lastD=d;}
    appendMsg(m);
  });
  scrollBot();
  syncAvatars();
});

socket.on('newMessage', msg=>{
  const wrap=document.getElementById('msgs');
  const rows=wrap.querySelectorAll('.row');
  if(rows.length>0){
    const ld=rows[rows.length-1].dataset.date;
    const nd=new Date(msg.createdAt).toDateString();
    if(ld!==nd) appendDate(new Date(msg.createdAt));
  }
  appendMsg(msg);
  scrollBot();
});

socket.on('reactionUpdate', ({msgId, reactions})=>{
  const row=document.querySelector(`[data-id="${msgId}"]`);
  if(!row) return;
  let rrow=row.querySelector('.reactions-row');
  if(!rrow){rrow=document.createElement('div');rrow.className='reactions-row';row.querySelector('.bbl').appendChild(rrow);}
  renderReactions(rrow, reactions, msgId);
});

socket.on('typing', d=>{if(d.sender!==ME){document.getElementById('typName').textContent=OTHER_NAME;document.getElementById('typRow').classList.add('show');scrollBot();}});
socket.on('stopTyping', ()=>document.getElementById('typRow').classList.remove('show'));

socket.on('onlineStatus', status=>{
  const el=document.getElementById('statusTxt');
  if(status[OTHER]){el.textContent='online';el.className='hdr-status on';}
  else{el.textContent='last seen recently';el.className='hdr-status';}
});

socket.on('avatarUpdate', ({user,avatar})=>{
  if(user===OTHER){
    updateAvEl('otherAv',avatar);
    document.querySelectorAll('.msg-av.oth').forEach(a=>setAvImg(a,avatar));
  } else {
    const prev=document.getElementById('shAvPrev');
    setAvImg(prev,avatar);
  }
});

socket.on('messagesRead', ({by})=>{
  if(by===OTHER) document.querySelectorAll('.row.out .meta-tick').forEach(el=>{el.classList.add('rd');el.textContent='✓✓';});
});

// ── RENDER ──
function appendMsg(msg){
  const wrap=document.getElementById('msgs');
  const mine=msg.sender===ME;
  const row=document.createElement('div');
  row.className='row '+(mine?'out':'in');
  row.dataset.id=msg._id; row.dataset.date=new Date(msg.createdAt).toDateString();
  row.dataset.type=msg.type||'text'; row.dataset.content=msg.content||'';
  row.dataset.stk=msg.stickerUrl||''; row.dataset.sender=msg.sender;

  if(!mine){
    const av=document.createElement('div'); av.className='msg-av oth';
    const src=localStorage.getItem('av_'+OTHER);
    if(src) setAvImg(av,src); else av.textContent=OTHER_NAME[0];
    row.appendChild(av);
  }

  const bbl=document.createElement('div');
  if(msg.type==='sticker'){
    bbl.className='bbl stk';
    if(msg.replyTo?.sender) bbl.appendChild(mkRpBox(msg.replyTo));
    const img=document.createElement('img'); img.className='stk-img'; img.src=msg.stickerUrl; bbl.appendChild(img);
  } else {
    bbl.className='bbl';
    if(msg.replyTo?.sender) bbl.appendChild(mkRpBox(msg.replyTo));
    if(msg.type==='image'){
      const src=msg.fileData||msg.fileUrl;
      const img=document.createElement('img'); img.className='msg-img'; img.src=src;
      img.onclick=e=>{e.stopPropagation();openImgV(src);}; bbl.appendChild(img);
      if(msg.content){const t=document.createElement('div');t.textContent=msg.content;t.style.whiteSpace='pre-wrap';bbl.appendChild(t);}
    } else if(msg.type==='file'){
      const a=document.createElement('a'); a.className='file-row'; a.href=msg.fileUrl||msg.fileData; a.download=msg.fileName; a.target='_blank'; a.onclick=e=>e.stopPropagation();
      const ext=(msg.fileName||'').split('.').pop().toUpperCase();
      a.innerHTML=`<span class="file-ico">📄</span><div><div class="file-nm">${esc(msg.fileName)}</div><div class="file-sz">${fmtSz(msg.fileSize)} · ${ext}</div></div>`;
      bbl.appendChild(a);
    } else {
      const t=document.createElement('div'); t.style.whiteSpace='pre-wrap'; t.textContent=msg.content; bbl.appendChild(t);
    }
    // Reactions
    if(msg.reactions && msg.reactions.length>0){
      const rrow=document.createElement('div'); rrow.className='reactions-row';
      renderReactions(rrow, msg.reactions, msg._id);
      bbl.appendChild(rrow);
    }
    const meta=document.createElement('div'); meta.className='meta';
    const tm=document.createElement('span'); tm.className='meta-time'; tm.textContent=fmtTime(msg.createdAt); meta.appendChild(tm);
    if(mine){const tk=document.createElement('span');tk.className='meta-tick'+(msg.read?' rd':'');tk.textContent=msg.read?'✓✓':'✓';meta.appendChild(tk);}
    bbl.appendChild(meta);
  }
  row.appendChild(bbl);
  const arr=document.createElement('div'); arr.className='sw-arr'; arr.textContent='↩'; row.appendChild(arr);
  setupRowEvents(row, msg);
  wrap.insertBefore(row, document.getElementById('typRow'));
}

function mkRpBox(rp){
  const d=document.createElement('div'); d.className='rp-box';
  const name=rp.sender===ME?MY_NAME:OTHER_NAME;
  const txt=document.createElement('div'); txt.className='rp-txt';
  if(rp.type==='sticker'&&rp.stickerUrl){const img=document.createElement('img');img.className='rp-stk-th';img.src=rp.stickerUrl;txt.appendChild(img);txt.appendChild(document.createTextNode('Sticker'));}
  else{txt.textContent=rp.content||'Message';}
  d.innerHTML=`<div class="rp-name">${name}</div>`;
  d.appendChild(txt);
  d.onclick=e=>{e.stopPropagation();scrollToMsg(rp.id);};
  return d;
}

function renderReactions(container, reactions, msgId){
  container.innerHTML='';
  // Group by emoji
  const map={};
  reactions.forEach(r=>{ if(!map[r.emoji]) map[r.emoji]={count:0,byMe:false}; map[r.emoji].count++; if(r.by===ME)map[r.emoji].byMe=true; });
  Object.entries(map).forEach(([emoji,{count,byMe}])=>{
    const chip=document.createElement('div'); chip.className='reaction-chip'+(byMe?' mine':'');
    chip.textContent=emoji+(count>1?' '+count:'');
    chip.onclick=e=>{e.stopPropagation(); socket.emit('addReaction',{msgId,emoji:byMe?'':emoji,user:ME});};
    container.appendChild(chip);
  });
}

// ── SWIPE + LONG PRESS ──
function setupRowEvents(row, msg){
  let tx0=0,ty0=0,swiped=false,pressing=false,pressT=null;
  row.addEventListener('touchstart',e=>{
    tx0=e.touches[0].clientX; ty0=e.touches[0].clientY; swiped=false; pressing=true;
    pressT=setTimeout(()=>{if(pressing) showEmojiPicker(e.touches[0].clientX,e.touches[0].clientY,msg._id);},500);
  },{passive:true});
  row.addEventListener('touchmove',e=>{
    pressing=false; clearTimeout(pressT);
    const dx=e.touches[0].clientX-tx0, dy=Math.abs(e.touches[0].clientY-ty0);
    if(dy>20){row.style.transform='';return;}
    const dir=msg.sender===ME?-1:1, pull=dx*dir;
    if(pull>0&&pull<70){row.style.transform=`translateX(${dx}px)`;row.classList.add('sw');row.querySelector('.sw-arr').style.opacity=Math.min(pull/50,1);}
    if(pull>=55&&!swiped){swiped=true;setReply(msg);if(navigator.vibrate)navigator.vibrate(30);}
  },{passive:true});
  row.addEventListener('touchend',()=>{pressing=false;clearTimeout(pressT);row.style.transform='';row.classList.remove('sw');row.querySelector('.sw-arr').style.opacity=0;});
  row.addEventListener('contextmenu',e=>{e.preventDefault();showEmojiPicker(e.clientX,e.clientY,msg._id);});
}

// ── EMOJI REACTION PICKER ──
function showEmojiPicker(x,y,msgId){
  pickerMsgId=msgId;
  const p=document.getElementById('emojiPicker');
  const pw=200, ph=90;
  p.style.left=Math.min(x,window.innerWidth-pw-10)+'px';
  p.style.top=Math.max(y-ph-10,10)+'px';
  p.classList.add('show');
  if(navigator.vibrate) navigator.vibrate(20);
}
function pickEmoji(emoji){
  if(!pickerMsgId) return;
  document.getElementById('emojiPicker').classList.remove('show');
  socket.emit('addReaction',{msgId:pickerMsgId, emoji, user:ME});
  pickerMsgId=null;
}
function replyFromPicker(){
  document.getElementById('emojiPicker').classList.remove('show');
  if(!pickerMsgId) return;
  const row=document.querySelector(`[data-id="${pickerMsgId}"]`);
  if(!row) return;
  setReply({_id:pickerMsgId, sender:row.dataset.sender, type:row.dataset.type, content:row.dataset.content, stickerUrl:row.dataset.stk});
  pickerMsgId=null;
}
document.addEventListener('click',e=>{if(!e.target.closest('#emojiPicker')) document.getElementById('emojiPicker').classList.remove('show');});

// ── REPLY ──
function setReply(msg){
  replyData=msg;
  document.getElementById('rpName').textContent=msg.sender===ME?MY_NAME:OTHER_NAME;
  const txt=document.getElementById('rpTxt'); txt.innerHTML='';
  if(msg.type==='sticker'&&msg.stickerUrl){const img=document.createElement('img');img.className='rp-bar-stk';img.src=msg.stickerUrl;txt.appendChild(img);txt.appendChild(document.createTextNode('Sticker'));}
  else{txt.textContent=msg.content||msg.fileName||'Message';}
  document.getElementById('rpBar').classList.add('show');
  document.getElementById('stkPanel').classList.remove('show');
  document.getElementById('msgBox').focus();
}
function clearReply(){replyData=null;document.getElementById('rpBar').classList.remove('show');}
function mkRp(m){return{id:m._id,sender:m.sender,content:m.content||'',type:m.type||'text',stickerUrl:m.stickerUrl||''};}

// ── SEND ──
function doSend(){
  const box=document.getElementById('msgBox');
  const txt=box.value.trim(); if(!txt) return;
  const pl={sender:ME,type:'text',content:txt};
  if(replyData) pl.replyTo=mkRp(replyData);
  socket.emit('sendMessage',pl);
  box.value=''; box.style.height='auto'; clearReply(); stopTyp();
}

// ── TYPING ──
const msgBox=document.getElementById('msgBox');
msgBox.addEventListener('input',()=>{
  msgBox.style.height='auto'; msgBox.style.height=Math.min(msgBox.scrollHeight,120)+'px';
  if(!isTyp){isTyp=true;socket.emit('typing',{sender:ME});}
  clearTimeout(typTimer); typTimer=setTimeout(stopTyp,2000);
});
msgBox.addEventListener('keydown',e=>{if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();doSend();}});
function stopTyp(){if(isTyp){isTyp=false;socket.emit('stopTyping',{sender:ME});}clearTimeout(typTimer);}

// ── FILE ──
document.getElementById('fileInput').addEventListener('change',async e=>{
  const file=e.target.files[0]; if(!file) return;
  showToast('⏳ Uploading...');
  const fd=new FormData(); fd.append('file',file);
  try{
    const res=await fetch('/api/upload',{method:'POST',body:fd});
    const d=await res.json();
    const pl={sender:ME};
    if(d.isImage){pl.type='image';pl.fileData=d.dataUri;pl.fileName=d.name;pl.fileSize=d.size;}
    else{pl.type='file';pl.fileUrl=d.url;pl.fileName=d.name;pl.fileSize=d.size;}
    if(replyData) pl.replyTo=mkRp(replyData);
    socket.emit('sendMessage',pl); clearReply();
  }catch(err){showToast('❌ Upload failed',2500);}
  hideToast(); e.target.value='';
});

// ── STICKERS ──
async function loadStickers(){
  try{
    const res=await fetch('/api/stickers'); stickerPacks=await res.json();
    buildStickerUI();
  }catch(e){}
}
loadStickers();

function buildStickerUI(){
  const tabs=document.getElementById('stkTabs'); tabs.innerHTML='';
  const grid=document.getElementById('stkGrid'); grid.innerHTML='';
  if(!stickerPacks.length){grid.innerHTML='<div class="stk-empty">No stickers yet!<br>Admin se .wastickers file upload karwao 😊</div>';return;}
  stickerPacks.forEach((pack,i)=>{
    const tab=document.createElement('div'); tab.className='stk-tab'+(i===0?' active':'');
    tab.dataset.i=i;
    if(pack.icon){const img=document.createElement('img');img.src=pack.icon;tab.appendChild(img);}
    else{tab.textContent=pack.title[0].toUpperCase();}
    tab.onclick=()=>switchPack(i);
    tabs.appendChild(tab);
  });
  showPack(0);
}

function switchPack(i){
  activePack=i;
  document.querySelectorAll('.stk-tab').forEach((t,j)=>t.classList.toggle('active',j===i));
  showPack(i);
}

function showPack(i){
  const grid=document.getElementById('stkGrid'); grid.innerHTML='';
  const pack=stickerPacks[i]; if(!pack) return;
  pack.stickers.forEach(s=>{
    const cell=document.createElement('div'); cell.className='stk-cell';
    const img=document.createElement('img'); img.src=s.data; img.loading='lazy'; img.alt='';
    cell.appendChild(img); cell.onclick=()=>sendStk(s.data); grid.appendChild(cell);
  });
}

function toggleStk(){
  const p=document.getElementById('stkPanel');
  p.classList.toggle('show');
  if(p.classList.contains('show')) document.getElementById('msgBox').blur();
}
function sendStk(dataUri){
  const pl={sender:ME,type:'sticker',stickerUrl:dataUri};
  if(replyData) pl.replyTo=mkRp(replyData);
  socket.emit('sendMessage',pl); clearReply();
  document.getElementById('stkPanel').classList.remove('show');
}

// ── CALL ──
function triggerCall(){ socket.emit('callOnline',{caller:ME}); showToast('📞 Online status sent!',2500); }

// ── THEME ──
const THEMES={
  dark:'none',ocean:'none',purple:'none',green:'none',
  pink:'none',sunset:'none',cherry:'none',night:'none'
};
const THEME_GRADS={
  dark:'linear-gradient(135deg,#1a1a2e,#16213e,#0f3460)',
  ocean:'linear-gradient(135deg,#0d1b2a,#1b2838,#2a475e)',
  purple:'linear-gradient(135deg,#1a0d2e,#2d1b4e,#1a0d3e)',
  green:'linear-gradient(135deg,#0d2818,#1a4228,#0d3818)',
  pink:'linear-gradient(135deg,#1f0d1a,#3a1530,#1f0d2e)',
  sunset:'linear-gradient(135deg,#1f1008,#3a2010,#1f1008)',
  cherry:'linear-gradient(135deg,#1a0808,#350f0f,#1a0808)',
  night:'none'
};
function openTheme(){document.getElementById('themePicker').classList.add('show');}
function closeTheme(){document.getElementById('themePicker').classList.remove('show');}
function closeThemeOutside(e){if(e.target===document.getElementById('themePicker'))closeTheme();}
function setTheme(id, grad){
  const body=document.getElementById('body');
  // Remove all theme classes
  ['dark','ocean','purple','green','pink','sunset','cherry','night'].forEach(t=>body.classList.remove('th-'+t));
  body.classList.add('th-'+id);
  document.getElementById('msgs').style.backgroundImage=THEME_GRADS[id]||grad;
  localStorage.setItem('chatTheme',id);
  document.querySelectorAll('.theme-swatch').forEach(s=>s.classList.toggle('active',s.dataset.id===id));
}
// Load saved theme
(function(){
  const t=localStorage.getItem('chatTheme')||'dark';
  setTheme(t, THEME_GRADS[t]);
})();

// ── AVATAR ──
function openAvSheet(){document.getElementById('avSheet').classList.add('show');syncSheetAv();}
function closeSheet(e){if(e.target===document.getElementById('avSheet'))document.getElementById('avSheet').classList.remove('show');}
function syncSheetAv(){const s=localStorage.getItem('av_'+ME);if(s)setAvImg(document.getElementById('shAvPrev'),s);}

document.getElementById('avInput').addEventListener('change',async e=>{
  const file=e.target.files[0]; if(!file) return;
  showToast('⏳ Uploading photo...');
  const fd=new FormData(); fd.append('avatar',file);
  try{
    const res=await fetch('/api/avatar/'+ME,{method:'POST',body:fd});
    const d=await res.json();
    if(d.avatar){localStorage.setItem('av_'+ME,d.avatar);setAvImg(document.getElementById('shAvPrev'),d.avatar);}
  }catch(err){showToast('❌ Failed',2000);}
  hideToast(); document.getElementById('avSheet').classList.remove('show'); e.target.value='';
});

function syncAvatars(){
  ['tanji','hinata'].forEach(u=>{
    fetch('/api/profile/'+u).then(r=>r.json()).then(p=>{
      if(p.avatar){
        localStorage.setItem('av_'+u,p.avatar);
        if(u===OTHER){
          updateAvEl('otherAv',p.avatar);
          document.querySelectorAll('.msg-av.oth').forEach(a=>setAvImg(a,p.avatar));
        } else { syncSheetAv(); }
      }
    }).catch(()=>{});
  });
}

function updateAvEl(id,src){ const el=document.getElementById(id); if(el) setAvImg(el,src); }
function setAvImg(el,src){
  let img=el.querySelector('img');
  if(!img){img=document.createElement('img');el.appendChild(img);try{el.childNodes[0].nodeType===3&&el.childNodes[0].remove();}catch(e){}}
  img.src=src;
}

// ── UTILS ──
function scrollBot(){const w=document.getElementById('msgs');w.scrollTop=w.scrollHeight;}
function scrollToMsg(id){const el=document.querySelector(`[data-id="${id}"]`);if(el){el.scrollIntoView({behavior:'smooth',block:'center'});el.classList.add('hl');setTimeout(()=>el.classList.remove('hl'),1200);}}
function fmtTime(ts){const d=new Date(ts);return d.getHours().toString().padStart(2,'0')+':'+d.getMinutes().toString().padStart(2,'0');}
function fmtSz(b){if(!b)return'0B';if(b<1024)return b+'B';if(b<1048576)return(b/1024).toFixed(1)+'KB';return(b/1048576).toFixed(1)+'MB';}
function esc(s){return(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function appendDate(d){
  const wrap=document.getElementById('msgs');
  const today=new Date().toDateString(),yest=new Date(Date.now()-86400000).toDateString();
  let lbl=d.toDateString()===today?'Today':d.toDateString()===yest?'Yesterday':d.toLocaleDateString('en-IN',{day:'numeric',month:'long',year:'numeric'});
  const div=document.createElement('div'); div.className='date-sep'; div.innerHTML=`<span>${lbl}</span>`;
  wrap.insertBefore(div,document.getElementById('typRow'));
}

let toastTimer=null;
function showToast(msg,dur){clearTimeout(toastTimer);const t=document.getElementById('toast');document.getElementById('toastMsg').textContent=msg;t.classList.add('show');if(dur){toastTimer=setTimeout(()=>t.classList.remove('show'),dur);}}
function hideToast(){clearTimeout(toastTimer);document.getElementById('toast').classList.remove('show');}
function openImgV(src){document.getElementById('ivImg').src=src;document.getElementById('imgV').classList.add('show');}
function closeImgV(){document.getElementById('imgV').classList.remove('show');}

// Close sticker on msg tap or input focus
document.getElementById('msgs').addEventListener('click',()=>document.getElementById('stkPanel').classList.remove('show'));
document.getElementById('msgBox').addEventListener('focus',()=>document.getElementById('stkPanel').classList.remove('show'));

// Mobile keyboard resize fix
if(window.visualViewport){
  window.visualViewport.addEventListener('resize',()=>{
    document.getElementById('app').style.height=window.visualViewport.height+'px';
    scrollBot();
  });
}
</script>
</body>
</html>
